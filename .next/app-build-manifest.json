{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/(dashboard)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/layout.js"
    ],
    "/(dashboard)/clients/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/clients/page.js"
    ],
    "/(dashboard)/clients/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/clients/[id]/page.js"
    ],
    "/(dashboard)/clients/[id]/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/clients/[id]/not-found.js"
    ],
    "/(dashboard)/projects/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/projects/[id]/page.js"
    ],
    "/(dashboard)/projects/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/projects/page.js"
    ],
    "/(dashboard)/workflows/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/workflows/page.js"
    ]
  }
}